<ui:FluentWindow x:Class="WinThemeService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:WinThemeService"
        mc:Ignorable="d"
        Title="WinThemeService"
        Width="480"
        Height="560"
        MinWidth="400"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="WinThemeService" ShowMaximize="False" ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/icon.png" Width="16" Height="16"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Current Theme Card -->
                <ui:Card Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Current Theme" FontSize="14" Opacity="0.7"/>
                            <TextBlock x:Name="CurrentThemeText" Text="Light" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ui:Button x:Name="ToggleThemeButton"
                                   Grid.Column="1"
                                   Appearance="Primary"
                                   Click="OnToggleThemeClick"
                                   ToolTip="Toggle between Light and Dark theme">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="WeatherSunny24" Margin="0,0,8,0"/>
                                <TextBlock Text="Toggle"/>
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                </ui:Card>

                <!-- Auto Switch Card -->
                <ui:Card Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Automatic Switching" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Automatically switch theme based on schedule" FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ui:ToggleSwitch x:Name="AutoSwitchToggle"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Click="OnAutoSwitchChanged"/>
                    </Grid>
                </ui:Card>

                <!-- Schedule Card -->
                <ui:Card x:Name="ScheduleCard" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Schedule" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Day Start -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Day Start (Light)" FontSize="13" Opacity="0.7" Margin="0,0,0,8"/>
                                <ui:TextBox x:Name="DayStartInput"
                                           PlaceholderText="07:00"
                                           TextChanged="OnScheduleInputChanged"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="—"
                                       VerticalAlignment="Bottom" Margin="16,0"
                                       Opacity="0.5" FontSize="20"/>

                            <!-- Day End -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Night Start (Dark)" FontSize="13" Opacity="0.7" Margin="0,0,0,8"/>
                                <ui:TextBox x:Name="DayEndInput"
                                           PlaceholderText="19:00"
                                           TextChanged="OnScheduleInputChanged"/>
                            </StackPanel>
                        </Grid>

                        <ui:Button x:Name="SaveScheduleButton"
                                   Appearance="Primary"
                                   Content="Save Schedule"
                                   Click="OnSaveScheduleClick"
                                   IsEnabled="False"
                                   Margin="0,16,0,0"/>
                    </StackPanel>
                </ui:Card>

                <!-- About Section -->
                <ui:Card Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="About" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock FontSize="13" Opacity="0.7" Margin="0,0,0,8">
                            <Run Text="WinThemeService v"/>
                            <Run x:Name="VersionText"/>
                        </TextBlock>
                        <TextBlock Text="Automatic Windows theme switcher with Task Scheduler support." FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </ui:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
